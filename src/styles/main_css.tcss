#app-grid {
    layout: grid;
    grid-size: 2;  /* two columns */
    grid-columns: 1fr;
}

#processes {
    background: $panel;
    border: round orange;
    border-title-color: $text;
    border-title-align: center;
    border-subtitle-color: $text;
    border-subtitle-align: center;
}

#processes:light {
    border: darkorange;
    background: $boost-darken-1;
}

#stats {
    layout: vertical;
    height: 1fr;
    /*border: greenyellow;*/
    /*border-title-color: $text;*/
    /*border-title-align: center;*/
}

#stats > Widget:light {
    background: $boost-darken-1;
}

#drives {
    background: $panel;
    border: round red;
    height: 1fr;
    border-title-color: $text;
    border-title-align: center;
    border-subtitle-color: $text;
    border-subtitle-align: center;
}

#mem {
    background: $panel;
    border: round yellow;
    height: 1fr;
    border-title-color: $text;
    border-title-align: center;
}

#mem:light {
    border: #F3CD00;
}

#cpu {
    background: $panel;
    border: round lightblue;
    height: 1fr;
    border-title-color: $text;
    border-title-align: center;
}

#cpu:light {
    border: blue 90%;
}

#network {
    background: $panel;
    border: round lightgreen;
    height: 1fr;
    border-title-color: $text;
    border-title-align: center;
    border-subtitle-color: $text;
    border-subtitle-align: center;
}

#network:light {
    border: green;
}

#gpu {
    background: $panel;
    border: round pink;
    height: 1fr;
    border-title-color: $text;
    border-title-align: center;
    border-subtitle-color: $text;
    border-subtitle-align: center;
}

#gpu:light {
    border: deeppink;
}

.proc {
    margin: 0 0 1 0;
}
